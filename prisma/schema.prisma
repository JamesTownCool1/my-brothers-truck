// ======================================================
// My Brothers Truck — Prisma Schema (PostgreSQL)
// ======================================================
// Represents the entire domain:
//   - Users (with dual role: customer + helper in one account)
//   - Vehicles (trucks owned by helpers)
//   - Jobs (moving requests posted by customers)
//   - Messages (in-app chat per job)
//   - Reviews (two-way rating system)
//   - Notifications (job accepted, nearby, etc.)
//   - NextAuth tables (Account, Session, VerificationToken)
// ======================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum UserRole {
  CUSTOMER
  HELPER
  ADMIN
}

enum JobStatus {
  OPEN        // posted, waiting for a helper
  ACCEPTED    // a helper claimed it
  IN_PROGRESS // helper started the move
  COMPLETED   // delivery confirmed
  CANCELLED   // cancelled by either side
}

enum JobSize {
  SMALL   // fits in a sedan trunk — small boxes, groceries
  MEDIUM  // TV, desk, mattress — fits in a pickup bed
  LARGE   // couch, fridge, appliance — needs a full-size truck
  XLARGE  // multiple large items / partial room-move
}

enum NotificationType {
  JOB_NEW_NEARBY    // helper: a new job was posted near you
  JOB_ACCEPTED      // customer: your job got picked up
  JOB_IN_PROGRESS   // customer: helper is on the way
  JOB_COMPLETED     // both: job marked complete
  JOB_CANCELLED     // both: job cancelled
  NEW_MESSAGE       // both: new chat message
  NEW_REVIEW        // both: someone reviewed you
}

// ---------- Core models ----------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  password        String?   // bcrypt hash; null for OAuth-only users
  name            String
  phone           String?
  bio             String?
  image           String?   // profile photo URL
  role            UserRole  @default(CUSTOMER)
  isHelperActive  Boolean   @default(false) // online/offline toggle for helpers

  // Helper-specific home base (used for proximity matching when they have no vehicle location)
  baseLat         Float?
  baseLng         Float?
  baseAddress     String?

  // Aggregate rating (denormalized for fast reads — recomputed on review)
  avgRating       Float     @default(0)
  ratingCount     Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  vehicles          Vehicle[]
  jobsAsCustomer    Job[]          @relation("CustomerJobs")
  jobsAsHelper      Job[]          @relation("HelperJobs")
  messagesSent      Message[]
  reviewsGiven      Review[]       @relation("Reviewer")
  reviewsReceived   Review[]       @relation("Reviewee")
  notifications     Notification[]

  @@index([role])
  @@index([isHelperActive])
}

model Vehicle {
  id          String   @id @default(cuid())
  ownerId     String
  make        String
  model       String
  year        Int
  color       String?
  licensePlate String?
  capacity    JobSize  @default(MEDIUM) // largest size the truck can handle
  photoUrl    String?
  createdAt   DateTime @default(now())

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model Job {
  id             String     @id @default(cuid())
  customerId     String
  helperId       String?    // null until someone accepts

  // Pickup
  pickupAddress  String
  pickupLat      Float
  pickupLng      Float

  // Dropoff
  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float

  // Item details
  title          String     // e.g. "Move TV from Best Buy"
  description    String     @db.Text
  size           JobSize
  imageUrl       String?

  // Timing
  preferredTime  DateTime

  // Money (in cents to avoid float issues)
  estimatedPriceCents Int
  finalPriceCents     Int?   // helper can override on accept
  distanceMeters      Int    // straight-line distance pickup -> dropoff

  status         JobStatus  @default(OPEN)

  // Lifecycle timestamps
  acceptedAt     DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?

  // Payment
  paymentIntentId String?   // Stripe PaymentIntent id
  paidAt         DateTime?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer       User       @relation("CustomerJobs", fields: [customerId], references: [id])
  helper         User?      @relation("HelperJobs",   fields: [helperId],   references: [id])
  messages       Message[]
  reviews        Review[]

  @@index([status])
  @@index([customerId])
  @@index([helperId])
  @@index([pickupLat, pickupLng]) // spatial queries use this
  @@index([createdAt])
}

model Message {
  id        String   @id @default(cuid())
  jobId     String
  senderId  String
  body      String   @db.Text
  readAt    DateTime?
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId],    references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([jobId, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  jobId      String
  reviewerId String
  revieweeId String
  rating     Int      // 1..5
  comment    String?  @db.Text
  hidden     Boolean  @default(false) // admin can hide abusive reviews
  createdAt  DateTime @default(now())

  job       Job  @relation(fields: [jobId],       references: [id], onDelete: Cascade)
  reviewer  User @relation("Reviewer",  fields: [reviewerId], references: [id])
  reviewee  User @relation("Reviewee",  fields: [revieweeId], references: [id])

  @@unique([jobId, reviewerId]) // one review per user per job
  @@index([revieweeId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  jobId     String?          // optional link to a job
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

// ---------- NextAuth.js tables ----------

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
