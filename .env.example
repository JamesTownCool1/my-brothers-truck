# ======================================================
# My Brothers Truck — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# ======================================================

# --- Database (PostgreSQL) ---
# For local dev with Docker: postgres://postgres:postgres@localhost:5432/mbt
# For Railway / Supabase / Neon: paste their connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mbt?schema=public"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Google Maps (client-side + geocoding) ---
# Create at: https://console.cloud.google.com/ — enable Maps JavaScript API + Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Stripe (test mode) ---
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Application ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin bootstrap (email of user to be auto-promoted to admin on first login) ---
ADMIN_EMAIL="admin@example.com"
